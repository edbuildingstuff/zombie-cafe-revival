; Engine configuration file.
; Minimal Godot 4 project used to validate that the asset tree
; produced by `go run ./tool/build_tool -target godot` is importable
; by Godot's built-in importers without manual intervention.
;
; This is a scaffold — not the real Godot client. It exists so the
; Phase 1 asset builder's output can be tested against actual Godot
; behavior instead of relying on "this should work" claims.

config_version=5

[application]

config/name="Zombie Cafe Revival — Asset Validation"
config/description="Phase 1 asset tree import validation scaffold."
